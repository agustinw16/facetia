# ARCHIVO DE EJEMPLO - SIN SECRETOS REALES
# -----------------------------------------------------------------------------
# Copiar este archivo a ".env" (en la misma carpeta) y completar con los valores reales.
# El archivo .env NO debe subirse al repo (esta en .gitignore).
# -----------------------------------------------------------------------------

# === META / WHATSAPP CLOUD API ===

# Token que VOS inventas y configuras en el panel de Meta for Developers
# en la seccion "Webhook -> Verify Token". Meta lo va a enviar en el handshake GET
# para confirmar que el webhook es tuyo. Puede ser cualquier string secreto.
META_VERIFY_TOKEN=

# Token Bearer que Meta te da para autorizarte a ENVIAR mensajes via Graph API.
# Se obtiene en Meta for Developers -> tu app -> WhatsApp -> API Setup -> Temporary access token.
# OJO: el token temporal dura 24 horas. Para produccion hay que generar uno permanente
# desde "System Users".
META_ACCESS_TOKEN=

# ID del numero de telefono asignado a tu app (NO es el numero en si, es un ID interno de Meta).
# Se obtiene en Meta for Developers -> tu app -> WhatsApp -> API Setup -> "Phone number ID".
META_PHONE_NUMBER_ID=

# URL completa para enviar mensajes via Graph API.
# Formato: https://graph.facebook.com/v21.0/{META_PHONE_NUMBER_ID}/messages
# Se puede armar dinamicamente desde config.py, pero la dejamos aca para mayor visibilidad.
META_API_URL=https://graph.facebook.com/v21.0/TU_PHONE_NUMBER_ID/messages

# === SERVIDOR ===

# Puerto donde escucha Flask. Render lo asigna automaticamente via env var PORT;
# si no esta definido, usamos 5000 para desarrollo local.
PORT=5000

# Si esta en "production", desactiva el modo debug de Flask.
# En desarrollo dejar en "development" para ver errores detallados.
FLASK_ENV=development
